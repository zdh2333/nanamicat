{
  "name": "nanamicat-meowgrid",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env server.js",
    "build": "node scripts/generate-sitemap.mjs && vite build",
    "start": "node --env-file-if-exists=.env server.js",
    "test:puzzles": "node scripts/validate-puzzles.mjs",
    "sync:puzzles": "node scripts/sync-puzzle-data.mjs",
    "validate:puzzles": "node scripts/validate-puzzle-manifest.mjs NanamiCat-iOS/NanamiCat/Resources/puzzle-data.json",
    "validate:translations": "node scripts/validate-translations.mjs",
    "test:adsense": "node --test tests/adsense-head.test.mjs",
    "test:visual:ja": "node scripts/visual-ja/sweep.mjs",
    "test:leaderboard": "node --test tests/leaderboard-sync.test.mjs",
    "test:puzzle-difficulty": "node --test tests/puzzle-difficulty.test.mjs",
    "test:static-pages": "node --test tests/static-pages.test.mjs",
    "test:visual:ja:remote": "JA_BASE=https://nanamicat.com node scripts/visual-ja/sweep.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "nodemailer": "^8.0.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.1.0"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
