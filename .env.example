ADMIN_KEY=replace-with-a-long-random-secret
PORT=4173

# Optional automatic thank-you emails for visitors who leave an email.
# For Gmail, use an app password, not your normal account password.
MAIL_FROM=noreply@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-account@gmail.com
SMTP_PASS=replace-with-gmail-app-password

# Production on Cloudflare Workers uses Resend instead of Gmail SMTP.
# Add this with: npx wrangler secret put RESEND_API_KEY
RESEND_API_KEY=re_xxxxxxxxx
